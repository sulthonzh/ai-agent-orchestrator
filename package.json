{
  "name": "ai-agent-orchestrator",
  "version": "1.0.0",
  "description": "Zero-dependency orchestration platform for AI agents with lifecycle management, workflow coordination, and intelligent load balancing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-agent-orchestrator": "dist/cli.js",
    "aaor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "orchestration",
    "agents",
    "workflow",
    "coordination",
    "kubernetes",
    "claude",
    "openai",
    "multi-agent",
    "automation"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/ai-agent-orchestrator.git"
  },
  "homepage": "https://github.com/sulthonzh/ai-agent-orchestrator#readme",
  "bugs": {
    "url": "https://github.com/sulthonzh/ai-agent-orchestrator/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
